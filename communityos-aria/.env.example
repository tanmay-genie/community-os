# ── CommunityOS Backend ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/communityos
REDIS_URL=redis://localhost:6379/0

# ── T2T Backend ──────────────────────────────────────────────
T2T_BASE_URL=http://localhost:8000
T2T_ADMIN_SECRET=admin-secret-change-in-prod

# ── LiveKit (voice pipeline) ─────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM ──────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# ── STT / TTS ────────────────────────────────────────────────
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── MCP Server ───────────────────────────────────────────────
MCP_SERVER_PORT=9000
ARIA_SERVER_NAME=ARIA
APP_ENV=development
