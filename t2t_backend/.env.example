# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/t2t_db
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/t2t_db

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ───────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-strong-random-secret
LOG_LEVEL=INFO

# ── Admin ─────────────────────────────────────────────
ADMIN_SECRET=admin-secret-change-in-prod

# ── Idempotency ───────────────────────────────────────
IDEMPOTENCY_TTL_SECONDS=86400

# ── SLA ───────────────────────────────────────────────
DEFAULT_ESCALATION_SLA_MINUTES=60

# ── WebSocket ─────────────────────────────────────────
WS_AUTH_TIMEOUT_SECONDS=10

# ── Loop Detection ────────────────────────────────────
LOOP_DETECTION_MAX_HOPS=20

# ── LLM (AI Brain) ───────────────────────────────────
LLM_PROVIDER=openai                    # "openai" or "anthropic"
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini                  # or "claude-sonnet-4-20250514"
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=30
